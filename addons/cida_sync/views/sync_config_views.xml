<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================================================== -->
    <!-- Configuración de Sync — Formulario                 -->
    <!-- ================================================== -->
    <record id="view_cida_sync_config_form" model="ir.ui.view">
        <field name="name">cida.sync.config.form</field>
        <field name="model">cida.sync.config</field>
        <field name="arch" type="xml">
            <form string="Configuración de Sincronización">
                <header>
                    <button name="action_test_connection"
                            string="🔌 Probar Conexión"
                            type="object"
                            class="btn-primary"
                            invisible="state == 'connected'"/>
                    <button name="action_test_connection"
                            string="🔌 Re-probar Conexión"
                            type="object"
                            invisible="state != 'connected'"/>
                    <button name="action_sync_now"
                            string="🔄 Sincronizar Ahora"
                            type="object"
                            class="btn-success"
                            invisible="state != 'connected'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,connected"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nombre de la sede remota"/></h1>
                    </div>
                    <group>
                        <group string="Este Nodo">
                            <field name="node_role"/>
                            <field name="conflict_resolution"/>
                            <field name="sync_interval_minutes"/>
                        </group>
                        <group string="Conexión Remota">
                            <field name="remote_url" placeholder="http://odoo-turistica:8069"/>
                            <field name="remote_db"/>
                            <field name="remote_user"/>
                            <field name="remote_password" password="True"/>
                        </group>
                    </group>
                    <group>
                        <group string="Estadísticas">
                            <field name="last_sync_date"/>
                            <field name="total_synced"/>
                            <field name="total_pending"/>
                            <field name="total_errors"/>
                        </group>
                        <group string="Estado" invisible="not last_error">
                            <field name="last_error"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Reglas de Sincronización" name="rules">
                            <field name="rule_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="model_id"/>
                                    <field name="direction"/>
                                    <field name="match_field"/>
                                    <field name="batch_size"/>
                                    <field name="sync_on_create"/>
                                    <field name="sync_on_write"/>
                                    <field name="last_sync_date"/>
                                    <field name="active"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Historial" name="logs">
                            <button name="action_view_logs"
                                    string="📋 Ver Historial Completo"
                                    type="object"
                                    class="btn-link"/>
                            <field name="log_ids" readonly="1" limit="20">
                                <tree decoration-success="state == 'done'"
                                      decoration-danger="state == 'error'"
                                      decoration-warning="state == 'conflict'">
                                    <field name="create_date"/>
                                    <field name="operation"/>
                                    <field name="model_name"/>
                                    <field name="state"/>
                                    <field name="records_sent"/>
                                    <field name="records_received"/>
                                    <field name="duration_seconds"/>
                                    <field name="error_message"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Configuración — Lista -->
    <record id="view_cida_sync_config_tree" model="ir.ui.view">
        <field name="name">cida.sync.config.tree</field>
        <field name="model">cida.sync.config</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="node_role"/>
                <field name="remote_url"/>
                <field name="state"
                       decoration-success="state == 'connected'"
                       decoration-danger="state == 'error'"
                       widget="badge"/>
                <field name="last_sync_date"/>
                <field name="total_synced"/>
                <field name="total_errors"/>
            </tree>
        </field>
    </record>

    <!-- Configuración — Acción -->
    <record id="action_cida_sync_config" model="ir.actions.act_window">
        <field name="name">Configuración de Sync</field>
        <field name="res_model">cida.sync.config</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
