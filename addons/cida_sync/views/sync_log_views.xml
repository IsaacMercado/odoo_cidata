<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================================================== -->
    <!-- Log de Sincronización — Lista                      -->
    <!-- ================================================== -->
    <record id="view_cida_sync_log_tree" model="ir.ui.view">
        <field name="name">cida.sync.log.tree</field>
        <field name="model">cida.sync.log</field>
        <field name="arch" type="xml">
            <tree decoration-success="state == 'done'"
                  decoration-danger="state == 'error'"
                  decoration-warning="state == 'conflict'"
                  decoration-info="state == 'running'"
                  default_order="create_date desc">
                <field name="create_date"/>
                <field name="config_id"/>
                <field name="operation"/>
                <field name="model_name"/>
                <field name="state" widget="badge"/>
                <field name="records_sent"/>
                <field name="records_received"/>
                <field name="records_created"/>
                <field name="records_updated"/>
                <field name="records_errored"/>
                <field name="duration_seconds" widget="float_time"/>
                <field name="error_message"/>
            </tree>
        </field>
    </record>

    <!-- Log — Formulario -->
    <record id="view_cida_sync_log_form" model="ir.ui.view">
        <field name="name">cida.sync.log.form</field>
        <field name="model">cida.sync.log</field>
        <field name="arch" type="xml">
            <form string="Detalle de Sincronización" create="false" edit="false">
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="config_id"/>
                            <field name="rule_id"/>
                            <field name="operation"/>
                            <field name="model_name"/>
                            <field name="create_date"/>
                            <field name="duration_seconds"/>
                        </group>
                        <group>
                            <field name="records_sent"/>
                            <field name="records_received"/>
                            <field name="records_created"/>
                            <field name="records_updated"/>
                            <field name="records_skipped"/>
                            <field name="records_errored"/>
                        </group>
                    </group>
                    <group string="Error" invisible="not error_message">
                        <field name="error_message" nolabel="1"/>
                    </group>
                    <group string="Detalle Técnico" invisible="not detail">
                        <field name="detail" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Log — Búsqueda -->
    <record id="view_cida_sync_log_search" model="ir.ui.view">
        <field name="name">cida.sync.log.search</field>
        <field name="model">cida.sync.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="model_name"/>
                <field name="config_id"/>
                <filter string="Completados" name="done"
                        domain="[('state', '=', 'done')]"/>
                <filter string="Errores" name="errors"
                        domain="[('state', '=', 'error')]"/>
                <filter string="Conflictos" name="conflicts"
                        domain="[('state', '=', 'conflict')]"/>
                <filter string="Hoy" name="today"
                        domain="[('create_date', '>=', (context_today()).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Estado" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Modelo" name="group_model"
                            context="{'group_by': 'model_name'}"/>
                    <filter string="Operación" name="group_op"
                            context="{'group_by': 'operation'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Log — Acción -->
    <record id="action_cida_sync_log" model="ir.actions.act_window">
        <field name="name">Historial de Sync</field>
        <field name="res_model">cida.sync.log</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_today': 1}</field>
    </record>

</odoo>
