<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_groups_privilege_shell_terminal" model="res.groups.privilege">
        <field name="name">Shell Terminal</field>
    </record>

    <record id="group_shell_terminal_user" model="res.groups">
        <field name="name">Odoo Shell User</field>
        <field name="privilege_id" ref="res_groups_privilege_shell_terminal"/>
        <field name="implied_ids" eval="[Command.link(ref('base.group_user'))]"/>
        <field name="comment">Can access the Odoo Shell Terminal and live log viewer from the systray. Requires the user to already be a Technical Administrator (group_system).</field>
    </record>
</odoo>
