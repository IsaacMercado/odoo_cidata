<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_base_synchro_log_tree" model="ir.ui.view">
        <field name="name">base.synchro.log.tree</field>
        <field name="model">base.synchro.log</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'done'"
                  decoration-danger="state == 'error'"
                  default_order="create_date desc">
                <field name="create_date"/>
                <field name="server_id"/>
                <field name="operation"/>
                <field name="model_name"/>
                <field name="state" widget="badge"/>
                <field name="records_sent"/>
                <field name="records_received"/>
                <field name="records_errored"/>
                <field name="duration_seconds" widget="float_time"/>
                <field name="error_message"/>
            </list>
        </field>
    </record>

    <record id="view_base_synchro_log_form" model="ir.ui.view">
        <field name="name">base.synchro.log.form</field>
        <field name="model">base.synchro.log</field>
        <field name="arch" type="xml">
            <form string="Detalle de Sincronización" create="false" edit="false">
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="server_id"/>
                            <field name="rule_id"/>
                            <field name="operation"/>
                            <field name="model_name"/>
                            <field name="create_date"/>
                            <field name="duration_seconds" widget="float_time"/>
                        </group>
                        <group>
                            <field name="records_sent"/>
                            <field name="records_received"/>
                            <field name="records_created"/>
                            <field name="records_updated"/>
                            <field name="records_skipped"/>
                            <field name="records_errored"/>
                        </group>
                    </group>
                    <group string="Error" invisible="not error_message">
                        <field name="error_message" nolabel="1"/>
                    </group>
                    <group string="Detalle Técnico" invisible="not detail">
                        <field name="detail" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_base_synchro_log_search" model="ir.ui.view">
        <field name="name">base.synchro.log.search</field>
        <field name="model">base.synchro.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="model_name" filter_domain="[('model_name', 'ilike', self)]" string="Modelo"/>
                <field name="server_id" filter_domain="[('server_id', '=', self)]" string="Servidor"/>
                <filter string="Completados" name="done"
                        domain="[('state', '=', 'done')]"/>
                <filter string="Errores" name="errors"
                        domain="[('state', '=', 'error')]"/>
                <filter string="Hoy" name="today"
                        domain="[('create_date', '&gt;=', (context_today()).strftime('%Y-%m-%d'))]"/>
                <group>
                    <filter string="Estado" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Modelo" name="group_model"
                            context="{'group_by': 'model_name'}"/>
                    <filter string="Operación" name="group_op"
                            context="{'group_by': 'operation'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_base_synchro_log" model="ir.actions.act_window">
        <field name="name">Historial de Sync</field>
        <field name="res_model">base.synchro.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_base_synchro_log_search"/>
        <field name="context">{'search_default_today': 1}</field>
    </record>

    <menuitem action="action_base_synchro_log"
              id="menu_base_synchro_log"
              parent="base_synchro.next_id_63"
              sequence="3"/>

</odoo>
