# ============================================================
# Odoo CIDA — Variables de Entorno
# ============================================================
# Copia este archivo como .env y modifica los valores.
#   cp .env.example .env
#
# SEDE CENTRAL:  NODE_ROLE=central,  NODE_ID=central-001
# SEDE TURÍSTICA: NODE_ROLE=turistica, NODE_ID=turistica-001
# ============================================================
#
# ⚠️  Las CONTRASEÑAS no van aquí. Se almacenan cifradas
#     via "podman secret". El script setup.sh las genera
#     automáticamente.
#
# ============================================================

# --- Identidad del Nodo ---
NODE_ROLE=central
NODE_ID=central-001
REMOTE_NODE_ID=turistica-001

# --- PostgreSQL (sin contraseñas) ---
POSTGRES_USER=odoo
POSTGRES_DB=odoo

# --- Puertos del host ---
# Se usan puertos no privilegiados por defecto para funcionar
# con Docker/Podman rootless sin tocar sysctl del sistema.
HOST_BIND_IP=0.0.0.0
HOST_HTTP_PORT=8080
HOST_HTTPS_PORT=8443
HOST_ODOO_PORT=8069

# --- Rangos de Secuencias ---
# Central:   1          → 100,000,000
# Turística: 100,000,001 → 200,000,000
SEQUENCE_START=1
SEQUENCE_END=100000000

# --- Backup ---
BACKUP_RETENTION_DAYS=7
BACKUP_INTERVAL_HOURS=6
